{
    // 使用 IntelliSense 了解相关属性。 
    // 悬停以查看现有属性的描述。
    // 欲了解更多信息，请访问: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
    {
        "type": "stlinkgdbtarget",
        "request": "launch",
        "name": "STM32Cube: Launch ST-Link GDB Server",
        "origin": "snippet",
        "cwd": "${workspaceFolder}",
        "preBuild": "${command:st-stm32-ide-debug-launch.build}",
        "runEntry": "main",
        "imagesAndSymbols": [
            {
                "imageFileName": "${command:st-stm32-ide-debug-launch.get-projects-binary-from-context1}"
            }
        ]
    },
        
        {
            "name": "DAP Wireless Debug",
            "cwd": "${workspaceFolder}",
            "executable": "${workspaceFolder}/build/Debug/dog_actuator.elf",
            "request": "launch",
            "type": "cortex-debug",
            "runToEntryPoint": "main",
            "servertype": "openocd",
            "configFiles": [
                "interface/cmsis-dap.cfg",
                "target/stm32f1x.cfg"
            ],
            "openOCDLaunchCommands": ["transport select swd"],
            "device": "STM32F103C8"
        }
    ]
}